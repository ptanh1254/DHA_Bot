MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
ZALO_IMEI=<your-zalo-imei>
ZALO_USER_AGENT=<your-user-agent>
ZALO_COOKIE_JSON=[{"name":"zpsid","value":"your_zpsid"},{"name":"zpw_sek","value":"your_zpw_sek"}]
GEMINI_API_KEY=<your-gemini-api-key>
# Hoặc dùng GEMINI_API / GOOGLE_API_KEY nếu bạn quen tên biến đó
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=1024
ASK_MAX_CHARS_PER_MESSAGE=1500
ASK_MAX_MESSAGE_PARTS=6
